# Copie para .env (gitignored) e ajuste os valores.
#   cp .env.example .env
# O .env é lido automaticamente pelo docker compose.

# ---- PostgreSQL ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fintrack

# ---- API ----
# Development (default em dev via override) ou Production.
ASPNETCORE_ENVIRONMENT=Development

# ---- JWT ----
# Chave de assinatura (HS256): use >= 32 caracteres. NÃO use este valor em produção.
JWT_KEY=dev-only-super-secret-jwt-signing-key-change-me-32+chars
JWT_ISSUER=FinTrack
JWT_AUDIENCE=FinTrack
